‾0A//‾0D‾0A‾0D‾0A// =====================‾0D‾0A// T
unables‾0D‾0A// =====================‾0D‾0A$portion
Denominator = 1;    // 1 = full, 2 = half, 4 = quar
ter‾0D‾0A$beOffset           = 0.03; // BE trigger 
offset‾0D‾0A$cancelWaitMs       = 1000; // cancel t
hrottle wait‾0D‾0A‾0D‾0A// =====================‾0D
‾0A// 0) Feature toggle‾0D‾0A// ===================
