‾0A// - Most hotkeys assume these globals exist.‾0D
‾0A//‾0D‾0A‾0D‾0A// ---- 0) Runtime Counters & Mode
s ----‾0D‾0A// Counter for the 1-second timer scrip
t (see other scripts/timer.das)‾0D‾0A$oneSecondScri
ptCnt = 0;‾0D‾0A‾0D‾0A// Rehab mode: limit entries 
to ice-breaker size (1/4 normal size)‾0D‾0A$rehab =
 0;‾0D‾0A‾0D‾0A// ---- 1) Feature Toggles ----‾0D‾0A
$useSlippageMargin        = 1;     // 1=guard stop 
