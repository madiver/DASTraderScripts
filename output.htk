ymbol = "";‾0D‾0A‾0D‾0A// --- Capture pre-entry pos
ition & average cost (for TP logic) ---‾0D‾0A$posBe
fore = 0;‾0D‾0A$avgBefore = 0;‾0D‾0A‾0D‾0Aif (IsObj
($M)) {‾0D‾0A    $posBefore = $M.Pos;‾0D‾0A    $avg
Before = $M.AvgCost;‾0D‾0A} else {‾0D‾0A    $posBef
ore = Pos;‾0D‾0A    $avgBefore = AvgCost;‾0D‾0A}‾0D
‾0A‾0D‾0A// ---- Tunables ----‾0D‾0A$addShares     
= 100 * $qtyMult;‾0D‾0A$refPx             = BID;   
