ety failed for " + Symbol + "¥n" +‾0D‾0A           
"Bid: " + $bid + "  Ask: " + $ask + "  Spread: " + 
$spread + "¥n" +‾0D‾0A           "Planned Entry: " 
+ $pxEntry + "  Planned Stop: " + $hypoStop + "¥n¥n
";‾0D‾0A    if ($stopVsBidFail == 1)  { $msg = $msg
