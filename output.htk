symbol override‾0D‾0A$M = GetWindowObj("Primary_OE"
);‾0D‾0Aif (IsObj($M)) {‾0D‾0A    $entrySymbol = $M
.Symb;‾0D‾0A} else {‾0D‾0A    $entrySymbol = Symbol
;‾0D‾0A}‾0D‾0A$tpSymbol = "";‾0D‾0A‾0D‾0A// ---- Ca
