} else {‾0D‾0A    $entrySymbol = Symbol;‾0D‾0A}‾0D‾0A
$tpSymbol = "";‾0D‾0A‾0D‾0A// --- Capture pre-entry
 position & average cost (for TP logic) ---‾0D‾0A$p
osBefore = 0;‾0D‾0A$avgBefore = 0;‾0D‾0A‾0D‾0Aif (I
