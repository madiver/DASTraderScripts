tor‾0D‾0Aif ($tpSymbol != "" && $tpSymbol != $mySym
) {‾0D‾0A    $M.Symb = $tpSymbol;‾0D‾0A    Wait(300
); // allow DAS to fully update‾0D‾0A‾0D‾0A    $myS
ym = $M.Symb;‾0D‾0A    $myAcc = $M.Account;‾0D‾0A‾0D
