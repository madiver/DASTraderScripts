tKey("Set Take Profit");‾0D‾0A        } else {‾0D‾0A
            // Only reset TP if NOT yet profitable 
(bid <= avgBefore)‾0D‾0A            if ($bidNow <= 
$avgBefore) {‾0D‾0A                ExecHotKey("Set 
