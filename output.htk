$avgBefore = $M.AvgCost;‾0D‾0A} else {‾0D‾0A    $po
sBefore = Pos;‾0D‾0A    $avgBefore = AvgCost;‾0D‾0A
}‾0D‾0A‾0D‾0Aif ($rehab ==1 && $M.Pos > 0 && $ACCOU
NT_STATE == "live") {‾0D‾0A    MsgBox("ABORTED: Reh
ab size violation, scaling in not allowed!");‾0D‾0A
    return;‾0D‾0A}‾0D‾0A‾0D‾0A// Ice Breaker = 1/4 
of normal share size‾0D‾0A$quarter = 50 * $qtyMult 
* 0.25;‾0D‾0A$scaled = $quarter + 2.5;‾0D‾0A$addSha
res = $scaled - ($scaled % 5);‾0D‾0A‾0D‾0A// ---- T
unables ----‾0D‾0A$refPx             = BID;        
     // BID or ASK‾0D‾0A$minDelayMs  = 1000;       
    // throttle between order sends (ms)‾0D‾0A‾0D‾0A
// ---- Max position size guard rail ----‾0D‾0Aif (
$maxPositionSize > 0) {    ‾0D‾0A    // Determine c
urrent position in Primary_OE (fallback: Pos)‾0D‾0A
    $curPos = 0;‾0D‾0A    if (IsObj($M)) {‾0D‾0A   
