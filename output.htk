‾0Aif ($posNow > 0 && $avgNow <= 0) {‾0D‾0A    if (
$entryRefPx > 0) {‾0D‾0A        $avgNow = $entryRef
Px;‾0D‾0A    } else {‾0D‾0A        $avgNow = $M.Las
t;   // last fallback from montage‾0D‾0A    }‾0D‾0A
