($spreadTooWide == 1)  { $msg = $msg + "- SPREAD_TO
O_WIDE vs stopOff¥n"; }‾0D‾0A    MsgBox($msg + "¥nA
ction aborted.");‾0D‾0A    return;‾0D‾0A}‾0D‾0A‾0D‾0A
// Per-trade risk cap (projected risk = stopLossTri
gger * addShares)‾0D‾0Aif ($usePerTradeRiskCap == 1
