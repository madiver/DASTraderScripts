 2;     // minimum ticks to add as slippage margin‾0D
‾0A$slipSpreadFrac           = 0.25;  // additional
 margin = spread * this fraction‾0D‾0A$acceptPartia
l            = 1;     // 1=accept partial fill with
in window; 0=require full fill‾0D‾0A$minFillShares 
           = 1;     // minimum shares to accept whe
n $acceptPartial=1‾0D‾0A$cancelRemainderOnPartial =
 1;     // 1=cancel remainder before arming stop on
 partial‾0D‾0A$usePerTradeRiskCap       = 1;     //
 1=abort if projected risk exceeds cap‾0D‾0A$useSpr
eadCheck           = 1;     // 1=check spreads befo
re allowing buy order‾0D‾0A‾0D‾0A$useAutoStop = "Ye
s";‾0D‾0A$useTakeProfit = "Yes";‾0D‾0A$resetStopOnC
ancel = "Yes";‾0D‾0A‾0D‾0A// ---- 2) Risk & Executi
on Variables ----‾0D‾0A‾0D‾0A// Entry offset above/
below bid/ask (depending on strategy)‾0D‾0A// Examp
le: 0.01 = enter 1 cent(s) above BID (or below ASK)
‾0D‾0A$entryOffset = 0.03;‾0D‾0A‾0D‾0A// Exit offse
t above/below bid/ask (depending on strategy)‾0D‾0A
// Example: 0.01 = exit 1 cent(s) below BID (or abo
ve ASK)‾0D‾0A$exitOffset = 0.10;‾0D‾0A‾0D‾0A// Stop
 distance from entry, per share, in dollars (your "
1R")‾0D‾0A// Example: 0.10 = 10 cents risk per shar
e‾0D‾0A$stopLossTrigger = 0.10;‾0D‾0A‾0D‾0A// How m
any Rs ahead to place the take-profit alert‾0D‾0A//
 Example: 1.0 = take profit at +1R‾0D‾0A$takeProfit
Factor = 1.0;‾0D‾0A‾0D‾0A// Portion of your positio
n to sell/cover when the TP alert hits‾0D‾0A// Exam
ple: 0.50 = sell half at TP‾0D‾0A$takeProfitSize = 
0.50;‾0D‾0A‾0D‾0A// ---- 3) Account State (Simulati
on / Live Modes) ----‾0D‾0A//‾0D‾0A// You can toggl
e between sim/live elsewhere using ACCOUNT_STATE.‾0D
‾0A// These vars store your SIM and LIVE account id
entifiers.‾0D‾0A// If ACCOUNT_STATE is blank, we de
fault to live here.‾0D‾0A‾0D‾0Aif ($ACCOUNT_STATE =
= "") {‾0D‾0A    $ACCOUNT_STATE = "live";   // defa
ult to live if unset‾0D‾0A    $TRSIM  = "TR19644"; 
// your SIM trading account‾0D‾0A    $TRLIVE = "196
44";      // your LIVE trading account‾0D‾0A}‾0D‾0A
‾0D‾0A// ---- 4) Sizing & Risk Limits ----‾0D‾0A‾0D
‾0A// Multiplier for position sizing‾0D‾0A// Exampl
e: if base clip is 50 shares, qtyMult=4 -> 200 shar
es per entry‾0D‾0A$qtyMult = 4;‾0D‾0A‾0D‾0A// Maxim
um allowed position size (shares)‾0D‾0A$maxPosition
Size = $qtyMult * 150;‾0D‾0A‾0D‾0A// Maximum allowe
d $ risk *per trade*‾0D‾0A// Useful for guarding ag
ainst oversized positions or bad spreads‾0D‾0A$risk
CapDollars = 100.00;‾0D‾0A‾0D‾0A// Maximum allowed 
daily loss tracked by comparing‾0D‾0A// start-of-se
ssion equity vs current equity‾0D‾0A$maxDailyLoss =
 100.00;‾0D‾0A‾0D‾0A// Order entry fill wait parame
ters‾0D‾0A$pollMs           = 100;             // p
olling cadence (ms)‾0D‾0A$maxPolls       = 20;     
         // 20*100ms ‾7E= 2s‾0D‾0A‾0D‾0A// Initiali
ze session equity baseline for daily-loss guard‾0D‾0A
ExecHotKey("Initialize Session Equity");‾0D‾0A
